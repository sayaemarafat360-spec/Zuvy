<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night Theme - Same as default since app is dark by default -->
    <style name="Theme.Zuvy" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        
        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        
        <!-- Tertiary colors -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnBackground">@color/on_background_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightNavigationBar">false</item>
        
        <!-- Window -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowActivityTransitions">true</item>
        
        <!-- Ripple -->
        <item name="colorControlHighlight">@color/ripple_dark</item>
        
        <!-- Typography -->
        <item name="fontFamily">@font/poppins</item>
        <item name="android:fontFamily">@font/poppins</item>
        
        <!-- Shape -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Zuvy.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Zuvy.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Zuvy.LargeComponent</item>
        
        <!-- Card -->
        <item name="cardBackgroundColor">@color/card_dark</item>
        
        <!-- Dialog -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Zuvy.AlertDialog</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.Zuvy.BottomSheetDialog</item>
    </style>
</resources>
