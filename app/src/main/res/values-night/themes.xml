<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark Theme -->
    <style name="Theme.LudoBlitz" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        
        <!-- Background Colors -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnBackground">@color/on_background_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightNavigationBar">false</item>
        
        <!-- Typography -->
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        
        <!-- Animation -->
        <item name="android:windowAnimationStyle">@style/WindowAnimation</item>
        
        <!-- Ripple -->
        <item name="colorControlHighlight">@color/ripple_dark</item>
    </style>
    
    <!-- Card Styles Dark -->
    <style name="CardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_dark</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>
    
    <style name="CardStyle.Flat" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_variant_dark</item>
        <item name="cardCornerRadius">16dp</item>
    </style>
    
    <!-- Button Styles Dark -->
    <style name="ButtonSecondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">52dp</item>
    </style>
    
    <style name="ButtonIcon" parent="Widget.Material3.Button.Icon">
        <item name="backgroundTint">@color/transparent</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="iconTint">@color/text_primary_dark</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <style name="ButtonSocial" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="strokeColor">@color/divider_dark</item>
    </style>
    
    <!-- Input Styles Dark -->
    <style name="InputStyle" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/input_background_dark</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/text_secondary_dark</item>
        <item name="android:textColorHint">@color/text_tertiary_dark</item>
    </style>
    
    <!-- Typography Dark -->
    <style name="TextAppearance.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/text_primary_dark</item>
    </style>
    
    <style name="TextAppearance.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary_dark</item>
    </style>
    
    <style name="TextAppearance.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary_dark</item>
    </style>
    
    <style name="TextAppearance.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary_dark</item>
    </style>
    
    <style name="TextAppearance.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary_dark</item>
    </style>
    
    <style name="TextAppearance.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary_dark</item>
    </style>
    
    <!-- Chip Styles Dark -->
    <style name="ChipStyle" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipBackgroundColor">@color/surface_variant_dark</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>
    
    <style name="ChipFilter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface_variant_dark</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipCornerRadius">20dp</item>
    </style>
    
    <!-- Dialog Styles Dark -->
    <style name="DialogStyle" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="dialogCornerRadius">24dp</item>
        <item name="colorSurface">@color/surface_dark</item>
    </style>
    
    <style name="BottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@color/surface_dark</item>
        <item name="shapeAppearance">@style/ShapeAppearance.BottomSheet</item>
    </style>
    
    <!-- ProgressBar Dark -->
    <style name="ProgressBarStyle" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorColor">@color/primary</item>
        <item name="trackColor">@color/surface_variant_dark</item>
    </style>
    
    <!-- TabLayout Dark -->
    <style name="TabStyle" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/primary</item>
        <item name="tabSelectedTextColor">@color/primary</item>
        <item name="tabTextColor">@color/text_secondary_dark</item>
        <item name="tabTextAppearance">@style/TextAppearance.Subtitle</item>
    </style>
</resources>
