<?xml version="1.0" encoding="utf-8"?>
<!-- Compact Video Item Layout - Playit Style -->
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/card_dark"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <!-- Thumbnail Container - Compact Size -->
        <FrameLayout
            android:id="@+id/thumbnailContainer"
            android:layout_width="120dp"
            android:layout_height="68dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Thumbnail -->
            <ImageView
                android:id="@+id/thumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/surface_variant_dark"
                android:scaleType="centerCrop"
                tools:src="@drawable/ic_video_placeholder" />

            <!-- Gradient Overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/thumbnail_gradient" />

            <!-- Duration Badge -->
            <TextView
                android:id="@+id/duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="4dp"
                android:background="@drawable/bg_duration"
                android:fontFamily="@font/poppins"
                android:paddingHorizontal="5dp"
                android:paddingVertical="1dp"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:textStyle="bold"
                tools:text="12:34" />

            <!-- Play Icon Overlay -->
            <ImageView
                android:id="@+id/playIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:alpha="0.85"
                android:src="@drawable/ic_play"
                app:tint="@android:color/white" />

            <!-- Watched Progress Bar -->
            <View
                android:id="@+id/watchedProgress"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_gravity="bottom"
                android:background="#30FFFFFF" />

            <View
                android:id="@+id/watchedProgressBar"
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:layout_gravity="bottom"
                android:background="@color/primary"
                android:visibility="gone"
                tools:visibility="visible" />
            
            <!-- Selection Checkbox -->
            <CheckBox
                android:id="@+id/checkbox"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="top|start"
                android:layout_margin="4dp"
                android:buttonTint="@color/accent"
                android:visibility="gone"
                tools:visibility="visible" />
            
            <!-- Selection Overlay -->
            <View
                android:id="@+id/selectionOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#406C63FF"
                android:visibility="gone"
                tools:visibility="visible" />

        </FrameLayout>

        <!-- Video Info Container -->
        <LinearLayout
            android:id="@+id/infoContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@id/moreButton"
            app:layout_constraintStart_toEndOf="@id/thumbnailContainer"
            app:layout_constraintTop_toTopOf="@id/thumbnailContainer"
            app:layout_constraintBottom_toBottomOf="@id/thumbnailContainer"
            app:layout_constraintVertical_bias="0.0">

            <!-- Title -->
            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/poppins"
                android:lineSpacingExtra="1dp"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                tools:text="Amazing Video Title That Might Be Long" />

            <!-- Meta Info Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    tools:text="125 MB" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="2dp"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="4dp"
                    android:background="@color/text_secondary" />

                <TextView
                    android:id="@+id/resolution"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    tools:text="1080p" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="2dp"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="4dp"
                    android:background="@color/text_secondary" />

                <TextView
                    android:id="@+id/date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    tools:text="Today" />

            </LinearLayout>

            <!-- Path/Folder Info -->
            <TextView
                android:id="@+id/path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="middle"
                android:fontFamily="@font/poppins"
                android:maxLines="1"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:visibility="gone"
                tools:text="/storage/DCIM/Camera"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- More Options Button -->
        <ImageButton
            android:id="@+id/moreButton"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_circle_ripple"
            android:contentDescription="@string/more_options"
            android:padding="6dp"
            android:src="@drawable/ic_more_vertical"
            android:tint="@color/text_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/infoContainer" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
