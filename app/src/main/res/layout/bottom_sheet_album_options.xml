<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardBackgroundColor="@color/surface_variant_dark"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/albumArt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note" />

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/subtitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Options -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/optionPlay"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="start|center_vertical"
            android:text="Play All"
            android:textColor="@color/text_primary"
            app:icon="@drawable/ic_play"
            app:iconPadding="16dp"
            app:iconTint="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/optionShuffle"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="start|center_vertical"
            android:text="Shuffle All"
            android:textColor="@color/text_primary"
            app:icon="@drawable/ic_shuffle"
            app:iconPadding="16dp"
            app:iconTint="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/optionAddQueue"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="start|center_vertical"
            android:text="Add to Queue"
            android:textColor="@color/text_primary"
            app:icon="@drawable/ic_queue_music"
            app:iconPadding="16dp"
            app:iconTint="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/optionAddPlaylist"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="start|center_vertical"
            android:text="Add to Playlist"
            android:textColor="@color/text_primary"
            app:icon="@drawable/ic_playlist_outline"
            app:iconPadding="16dp"
            app:iconTint="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/optionGoArtist"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="start|center_vertical"
            android:text="Go to Artist"
            android:textColor="@color/text_primary"
            app:icon="@drawable/ic_artist"
            app:iconPadding="16dp"
            app:iconTint="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/optionShare"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="start|center_vertical"
            android:text="Share"
            android:textColor="@color/text_primary"
            app:icon="@drawable/ic_share"
            app:iconPadding="16dp"
            app:iconTint="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/optionDelete"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="start|center_vertical"
            android:text="Delete"
            android:textColor="@color/error"
            app:icon="@drawable/ic_delete"
            app:iconPadding="16dp"
            app:iconTint="@color/error" />

    </LinearLayout>

</LinearLayout>
