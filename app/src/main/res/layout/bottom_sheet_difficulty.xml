<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_players"
        android:textAppearance="@style/TextAppearance.Headline2" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupPlayers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip2Players"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/players_2"
            style="@style/ChipFilter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip3Players"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/players_3"
            style="@style/ChipFilter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip4Players"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/players_4"
            android:checked="true"
            style="@style/ChipFilter" />

    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_difficulty"
        android:textAppearance="@style/TextAppearance.Subtitle"
        android:layout_marginTop="16dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupDifficulty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipEasy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/easy"
            style="@style/ChipFilter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/medium"
            android:checked="true"
            style="@style/ChipFilter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipHard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hard"
            style="@style/ChipFilter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipExpert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/expert"
            style="@style/ChipFilter" />

    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartGame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/play_now"
        style="@style/ButtonPrimary" />

</LinearLayout>
