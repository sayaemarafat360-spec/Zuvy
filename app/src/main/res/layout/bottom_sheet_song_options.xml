<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:text="Song Options"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Media Info Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@color/surface_variant_dark"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle"
                android:padding="12dp"
                android:src="@drawable/ic_music_note"
                app:tint="@color/music_accent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/poppins_medium"
                    android:maxLines="2"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    tools:text="Song Title" />

                <TextView
                    android:id="@+id/subtitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/poppins"
                    android:maxLines="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    tools:text="Artist • 3:45" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Options List -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="8dp">

        <!-- Play Next -->
        <LinearLayout
            android:id="@+id/optionPlayNext"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_ripple"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_skip_next"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins"
                android:text="Play Next"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Add to Queue -->
        <LinearLayout
            android:id="@+id/optionAddQueue"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_ripple"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_list"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins"
                android:text="Add to Queue"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Add to Playlist -->
        <LinearLayout
            android:id="@+id/optionAddPlaylist"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_ripple"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_playlist_outline"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins"
                android:text="Add to Playlist"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Add to Favorites -->
        <LinearLayout
            android:id="@+id/optionAddFavorites"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_ripple"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_heart"
                app:tint="@color/music_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins"
                android:text="Add to Favorites"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="@color/divider_dark" />

        <!-- Go to Artist -->
        <LinearLayout
            android:id="@+id/optionGoArtist"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_ripple"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_artist"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins"
                android:text="Go to Artist"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Go to Album -->
        <LinearLayout
            android:id="@+id/optionGoAlbum"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_ripple"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_album"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins"
                android:text="Go to Album"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Set as Ringtone -->
        <LinearLayout
            android:id="@+id/optionRingtone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_ripple"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_music_note"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins"
                android:text="Set as Ringtone"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="@color/divider_dark" />

        <!-- Share -->
        <LinearLayout
            android:id="@+id/optionShare"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_ripple"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_share"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins"
                android:text="Share"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Details -->
        <LinearLayout
            android:id="@+id/optionDetails"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_ripple"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_info"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins"
                android:text="Details"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Delete -->
        <LinearLayout
            android:id="@+id/optionDelete"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_ripple"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_delete"
                app:tint="@color/error" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins"
                android:text="Delete"
                android:textColor="@color/error"
                android:textSize="15sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
