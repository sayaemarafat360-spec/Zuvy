<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_players"
            android:textAppearance="@style/TextAppearance.Headline2"
            android:layout_marginBottom="16dp" />

        <!-- Player Count Selection -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupPlayers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip2Players"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/players_2"
                style="@style/ChipFilter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip3Players"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/players_3"
                style="@style/ChipFilter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip4Players"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/players_4"
                android:checked="true"
                style="@style/ChipFilter" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Difficulty Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_difficulty"
            android:textAppearance="@style/TextAppearance.Subtitle"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupDifficulty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEasy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/easy"
                style="@style/ChipFilter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/medium"
                android:checked="true"
                style="@style/ChipFilter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hard"
                style="@style/ChipFilter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipExpert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/expert"
                style="@style/ChipFilter" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Game Mode Toggle -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/game_rules"
                        android:textAppearance="@style/TextAppearance.Subtitle" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchGameMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvGameModeDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/classic_desc"
                    android:textAppearance="@style/TextAppearance.Caption"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Game Mode Cards -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Game Modes"
            android:textAppearance="@style/TextAppearance.Subtitle"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <!-- Local Multiplayer -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLocalMultiplayer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_local"
                    android:tint="@color/primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/local_multiplayer"
                        android:textAppearance="@style/TextAppearance.Subtitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Play with friends on same device"
                        android:textAppearance="@style/TextAppearance.Caption" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- VS AI -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVsAi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_bot"
                    android:tint="@color/accent_teal" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/play_vs_ai"
                        android:textAppearance="@style/TextAppearance.Subtitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Challenge AI opponents"
                        android:textAppearance="@style/TextAppearance.Caption" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Online -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOnlineMultiplayer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_online"
                    android:tint="@color/secondary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/online_multiplayer"
                        android:textAppearance="@style/TextAppearance.Subtitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Play with players worldwide"
                        android:textAppearance="@style/TextAppearance.Caption" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Online Options -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnQuickMatch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/quick_match"
                style="@style/ButtonPrimary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateRoom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/create_room"
                style="@style/ButtonSecondary" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJoinRoom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/join_room"
            style="@style/ButtonSecondary" />

        <!-- Start Game Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Start Game"
            style="@style/ButtonPrimary" />

    </LinearLayout>

</ScrollView>
