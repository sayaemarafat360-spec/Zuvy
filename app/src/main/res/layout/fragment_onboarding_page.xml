<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="24dp">

    <!-- Illustration Container -->
    <FrameLayout
        android:id="@+id/illustrationContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/textContainer"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Animated Illustration -->
        <ImageView
            android:id="@+id/illustrationImage"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            tools:src="@drawable/ic_logo" />

        <!-- Glow Effect -->
        <View
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_glow_gradient"
            android:alpha="0.3" />

    </FrameLayout>

    <!-- Text Container -->
    <LinearLayout
        android:id="@+id/textContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/illustrationContainer">

        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            tools:text="Welcome to Zuvy" />

        <!-- Description -->
        <TextView
            android:id="@+id/descriptionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            tools:text="Your ultimate media player with powerful features and beautiful design." />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
