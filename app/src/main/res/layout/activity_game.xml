<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    tools:context=".ui.screens.GameActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Pause Button -->
        <ImageButton
            android:id="@+id/btnPause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/button_ripple"
            android:src="@drawable/ic_pause"
            android:tint="@color/text_primary" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Current Player -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCurrentPlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player 1"
                android:textAppearance="@style/TextAppearance.Subtitle" />

            <TextView
                android:id="@+id/tvTurnStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/your_turn"
                android:textAppearance="@style/TextAppearance.Caption"
                android:textColor="@color/success" />

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Auto Select -->
        <ImageButton
            android:id="@+id/btnAutoSelect"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/button_ripple"
            android:src="@drawable/ic_auto"
            android:tint="@color/text_primary" />

    </LinearLayout>

    <!-- Game Board Container -->
    <FrameLayout
        android:id="@+id/boardContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintBottom_toTopOf="@id/diceContainer"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <!-- Ludo Board -->
        <com.ludoblitz.app.ui.components.LudoBoardView
            android:id="@+id/boardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <!-- Player Cards (Overlays) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Top Players (Red & Yellow) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">

                <include
                    android:id="@+id/playerCardRed"
                    layout="@layout/item_player_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp" />

                <include
                    android:id="@+id/playerCardYellow"
                    layout="@layout/item_player_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp" />

            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Bottom Players (Green & Blue) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">

                <include
                    android:id="@+id/playerCardGreen"
                    layout="@layout/item_player_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp" />

                <include
                    android:id="@+id/playerCardBlue"
                    layout="@layout/item_player_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Dice Container -->
    <LinearLayout
        android:id="@+id/diceContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/boardContainer">

        <ImageView
            android:id="@+id/diceView"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_dice"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/roll_dice"
            android:textAppearance="@style/TextAppearance.Caption" />

    </LinearLayout>

    <!-- Celebration Animation -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/celebrationLottie"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Capture Animation -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/captureLottie"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Home Animation -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/homeLottie"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Reward Container -->
    <LinearLayout
        android:id="@+id/rewardContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvRewardCoins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+100"
            android:textAppearance="@style/TextAppearance.Headline1"
            android:textColor="@color/coin_gold" />

        <TextView
            android:id="@+id/tvRewardXp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+50 XP"
            android:textAppearance="@style/TextAppearance.Subtitle"
            android:textColor="@color/accent_teal" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
