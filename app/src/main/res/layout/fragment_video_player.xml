<?xml version="1.0" encoding="utf-8"?>
<FrameLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/player_background">

    <!-- Video View -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        app:artwork_display_mode="off"
        app:show_buffering="when_playing"
        app:surface_type="surface_view" />

    <!-- Gesture Overlay -->
    <LinearLayout
        android:id="@+id/gestureOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Left side - Brightness -->
        <View
            android:id="@+id/brightnessZone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- Right side - Volume -->
        <View
            android:id="@+id/volumeZone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Gesture Indicators -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="32dp">

        <!-- Brightness Indicator -->
        <LinearLayout
            android:id="@+id/brightnessIndicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="invisible">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_brightness"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/brightnessText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                tools:text="50%" />

        </LinearLayout>

        <!-- Seek Indicator -->
        <LinearLayout
            android:id="@+id/seekIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="invisible">

            <TextView
                android:id="@+id/seekText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@android:color/white"
                android:textSize="48sp"
                tools:text="+10s" />

            <TextView
                android:id="@+id/seekPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                tools:text="12:34 / 45:00" />

        </LinearLayout>

        <!-- Volume Indicator -->
        <LinearLayout
            android:id="@+id/volumeIndicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="invisible">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_volume"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/volumeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                tools:text="70%" />

        </LinearLayout>

    </LinearLayout>

    <!-- Custom Controls Overlay -->
    <FrameLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:background="@drawable/controls_gradient_top"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- Back -->
            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_ripple"
                android:contentDescription="@string/back"
                android:src="@drawable/ic_arrow_back"
                app:tint="@android:color/white" />

            <!-- Title -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/videoTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/poppins_semibold"
                    android:maxLines="1"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    tools:text="Video Title" />

                <TextView
                    android:id="@+id/videoInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/poppins"
                    android:maxLines="1"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp"
                    tools:text="1080p • 2.5 GB" />

            </LinearLayout>

            <!-- Top Actions -->
            <ImageButton
                android:id="@+id/pipButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_ripple"
                android:contentDescription="@string/pip_mode"
                android:src="@drawable/ic_pip"
                app:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/lockButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_circle_ripple"
                android:contentDescription="@string/screen_lock"
                android:src="@drawable/ic_lock_open"
                app:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/moreButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_circle_ripple"
                android:contentDescription="@string/more_options"
                android:src="@drawable/ic_more_vertical"
                app:tint="@android:color/white" />

        </LinearLayout>

        <!-- Center Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Rewind -->
            <LinearLayout
                android:id="@+id/rewindButton"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_circle_ripple"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_rewind"
                    app:tint="@android:color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_medium"
                    android:text="10"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Play/Pause -->
            < ImageButton
                android:id="@+id/playPauseButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginHorizontal="32dp"
                android:background="@drawable/bg_circle_ripple"
                android:contentDescription="@string/play"
                android:padding="16dp"
                android:src="@drawable/ic_play"
                app:tint="@android:color/white" />

            <!-- Forward -->
            <LinearLayout
                android:id="@+id/forwardButton"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_circle_ripple"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_forward"
                    app:tint="@android:color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_medium"
                    android:text="10"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Bottom Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/controls_gradient_bottom"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Progress Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/currentPosition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    tools:text="12:34" />

                <SeekBar
                    android:id="@+id/progressBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="30"
                    android:progressDrawable="@drawable/seekbar_progress"
                    android:thumb="@drawable/seekbar_thumb" />

                <TextView
                    android:id="@+id/duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    tools:text="45:00" />

            </LinearLayout>

            <!-- Bottom Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Speed -->
                <TextView
                    android:id="@+id/speedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded_small"
                    android:fontFamily="@font/poppins_semibold"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="1.0x"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

                <!-- Subtitles -->
                <ImageButton
                    android:id="@+id/subtitleButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_circle_ripple"
                    android:contentDescription="@string/subtitles"
                    android:src="@drawable/ic_subtitles"
                    app:tint="@android:color/white" />

                <!-- Audio Track -->
                <ImageButton
                    android:id="@+id/audioButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_circle_ripple"
                    android:contentDescription="@string/audio_track"
                    android:src="@drawable/ic_audio_track"
                    app:tint="@android:color/white" />

                <!-- Aspect Ratio -->
                <ImageButton
                    android:id="@+id/aspectRatioButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_circle_ripple"
                    android:contentDescription="@string/aspect_ratio"
                    android:src="@drawable/ic_aspect_ratio"
                    app:tint="@android:color/white" />

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Sleep Timer -->
                <ImageButton
                    android:id="@+id/sleepButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_ripple"
                    android:contentDescription="@string/sleep_timer"
                    android:src="@drawable/ic_sleep"
                    app:tint="@android:color/white" />

                <!-- Equalizer -->
                <ImageButton
                    android:id="@+id/equalizerButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_circle_ripple"
                    android:contentDescription="@string/equalizer"
                    android:src="@drawable/ic_equalizer"
                    app:tint="@android:color/white" />

                <!-- Rotate -->
                <ImageButton
                    android:id="@+id/rotateButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_circle_ripple"
                    android:contentDescription="@string/rotate"
                    android:src="@drawable/ic_rotate"
                    app:tint="@android:color/white" />

                <!-- Fullscreen -->
                <ImageButton
                    android:id="@+id/fullscreenButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_circle_ripple"
                    android:contentDescription="@string/fullscreen"
                    android:src="@drawable/ic_fullscreen"
                    app:tint="@android:color/white" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Lock Screen Overlay -->
    <LinearLayout
        android:id="@+id/lockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/unlockButton"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_ripple"
            android:contentDescription="@string/screen_lock"
            android:padding="16dp"
            android:src="@drawable/ic_lock"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/poppins"
            android:text="@string/screen_lock"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>
